# ================================================================
# Discord Bot - Variables de entorno (v2.0)
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env a GitHub
# ================================================================

# --- REQUERIDOS ---

# Token del bot de Discord (Discord Developer Portal)
DISCORD_TOKEN=tu_token_aqui

# URL del webhook de n8n que recibe los mensajes
N8N_WEBHOOK_URL=https://tu-instancia-n8n.com/webhook/discord-support

# ID del servidor de Discord (Guild ID) — necesario para comandos slash
DISCORD_GUILD_ID=1512616856043782277

# --- RECOMENDADOS ---

# Secreto para firmar los webhooks enviados a n8n (header X-Webhook-Secret)
N8N_WEBHOOK_SECRET=genera_un_secreto_aleatorio_largo_aqui

# ID del canal #escalaciones donde se envian alertas cuando un usuario pide humano
ESCALATION_CHANNEL_ID=id_del_canal_escalaciones

# ID del rol @Soporte (solo este rol puede usar /disconnected y /connected)
SUPPORT_ROLE_ID=id_del_rol_soporte

# --- OPCIONALES ---

# OpenAI API Key (solo si usas discord_bot_openai.py)
OPENAI_API_KEY=sk-proj-tu_key_aqui

# URL de Healthchecks.io (o similar) para monitoreo de uptime
# GET a esta URL cada 5 minutos; GET a URL/fail en caso de error
HEALTHCHECK_URL=https://hc-ping.com/tu-uuid-aqui

# Tiempo (en ms) antes de que el bot se auto-reactive tras /disconnected
# Default: 14400000 (4 horas)
HUMAN_HANDLING_TTL_MS=14400000

# Cooldown (en segundos) entre alertas de escalacion repetidas por canal
# Default: 900 (15 minutos)
ESCALATION_COOLDOWN_SECONDS=900
